{
  // Установить собственный шрифт и его размеры
  "editor.fontFamily": "'FiraCode Nerd Font', 'bold', bold",
  "editor.fontSize": 16,

  // Установить иконки и настроить их
  "workbench.iconTheme": "bearded-icons",
  "workbench.tree.indent": 14,

  // Запрашивать подтверждение на удаление и Drag&Drop
  "explorer.confirmDragAndDrop": true,
  "explorer.confirmDelete": true,

  // Убираем виджет справа для скролла
  "editor.scrollbar.horizontal": "hidden",
  "workbench.colorTheme": "Bearded Theme Monokai Metallian",
  "editor.minimap.enabled": false,
  "editor.occurrencesHighlight": "off",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.stickyScroll.enabled": false,

  // Убрать полный путь к файлу сверху
  "breadcrumbs.enabled": false,

  // Установить дефолтный размер для редактора
  "window.zoomLevel": 2,

  // Настройка курсора
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.cursorBlinking": "solid",

  // Плавность
  "editor.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,

  // Отключаем панель управления окном
  "chat.commandCenter.enabled": false,
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "window.titleBarStyle": "native",
  "window.menuBarVisibility": "toggle",

  // Настройка плагина todo
  "todohighlight.isEnable": true,

  // По дефолту открывать пустую страницу
  "workbench.startupEditor": "none",

  // Установить длину одного tab
  "editor.tabSize": 2,

  // Добавлять одну пустую строку в конец файла чтобы избежать ошибоки
  "files.insertFinalNewline": true,

  // Отключаем окно с помощью для новичков
  "workbench.tips.enabled": false,

  // Отключаем прилипание заголовка в деревьях
  "workbench.tree.enableStickyScroll": false,

  // Всегда использовать те отступы, которые заданы вручную (tabSize, insertSpaces и т.п.), а не угадывать.
  "editor.detectIndentation": false,

  // Отключает вертикальные линии отступов в редакторе
  "editor.guides.indentation": false,

  // Отключает подсветку активной строки
  "editor.renderLineHighlight": "none",

  // Автосохранение файлов через короткую паузу после редактирования
  "files.autoSave": "afterDelay",

  // Форматирование файлов
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,

  // Отключает автообновления
  "update.mode": "none",

  // Отключает всплывающие предложения установить расширения
  "extensions.ignoreRecommendations": true,

  // Отключает copilot
  "chat.disableAIFeatures": true,

  // Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  
  "python.analysis.typeCheckingMode": "basic",
}
